syntax on
set nocompatible
" Default color scheme
"let base16colorspace=256 " Access colors present in 256 colorspace
"set t_Co=256 " 256 color mode

"set background=dark

"colorscheme base16-ocean

"colorscheme torte
syntax on
set showmode
set showmatch
set ruler
set showcmd
set hlsearch
set ruler
"set directory=~/swp
nmap <CR> i<CR>
